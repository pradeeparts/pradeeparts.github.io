---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import Marquee from "../../components/Marquee.astro";
import CategoryGrid from "../../components/CategoryGrid.astro";
import PaintingCard from "../../components/PaintingCard.astro";
import Lightbox from "../../components/Lightbox.astro";
import { featured } from "../../data/paintings";
import { localizedPath } from "../../i18n/ui";
import { whatsappLink } from "../../config";

const lang = "hi";
---

<BaseLayout lang={lang}>
  <Hero lang={lang} />
  <Marquee lang={lang} />
  <CategoryGrid lang={lang} />

  <section class="py-20 sm:py-28 bg-[--color-ink-900] text-white">
    <div class="container-edge">
      <div data-reveal class="flex items-end justify-between flex-wrap gap-6 mb-12">
        <div>
          <div class="text-xs uppercase tracking-[0.22em] text-[--color-saffron-400] mb-3">चुनिंदा कार्य</div>
          <h2 class="text-4xl sm:text-5xl text-balance">हाल के कुछ कार्य</h2>
        </div>
        <a href={localizedPath("/work", lang)} class="text-sm font-medium text-white/80 hover:text-[--color-saffron-400] transition-colors flex items-center gap-2 group">
          सभी 33 कार्य देखें
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>

      <div data-reveal-stagger class="grid gap-4 sm:gap-5 grid-cols-2 lg:grid-cols-4">
        {featured.slice(0, 8).map((p, i) => (
          <PaintingCard painting={p} lang={lang} priority={i < 4} />
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 sm:py-32">
    <div class="container-edge">
      <div data-reveal class="max-w-4xl mx-auto text-center">
        <div class="text-xs uppercase tracking-[0.22em] text-[--color-vermillion-600] mb-4">कोट प्राप्त करें</div>
        <h2 class="text-5xl sm:text-7xl text-[--color-ink-900] text-balance leading-[1.05]">
          कोई दीवार<br/>मन में है?
        </h2>
        <p class="mt-7 text-lg sm:text-xl text-[--color-ink-600] max-w-xl mx-auto text-pretty">
          जगह की एक तस्वीर और अपना विचार WhatsApp पर भेजें। मैं एक दिन में कोट दूँगा।
        </p>
        <div class="mt-10">
          <a href={whatsappLink(lang)} target="_blank" rel="noopener" class="btn-primary text-base bg-[#25D366] hover:bg-[#1ebe5a] hover:!text-white">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1s-.8.9-.9 1.1c-.2.2-.3.2-.6.1-1.7-.9-2.9-1.5-4-3.5-.3-.5.3-.5.9-1.6.1-.2.1-.4 0-.5s-.7-1.6-.9-2.2c-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.2.2 2.1 3.2 5.1 4.5 1.9.8 2.6.9 3.5.7.6-.1 1.7-.7 2-1.4.2-.7.2-1.3.2-1.4-.1-.1-.3-.2-.6-.3zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.6 1.4 5.1L2 22l5-1.4c1.5.8 3.2 1.3 5 1.3 5.5 0 10-4.5 10-10S17.5 2 12 2z"/>
            </svg>
            WhatsApp पर संदेश भेजें
          </a>
        </div>
      </div>
    </div>
  </section>

  <Lightbox />
</BaseLayout>
