---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE, whatsappLink } from "../../config";
import { t, type Lang, ui } from "../../i18n/ui";

const lang: Lang = "hi";
const tr = t(lang);
const serves = ui[lang]["contact.serves"];
---

<BaseLayout lang={lang} title={String(tr("contact.title"))}>
  <section class="pt-14 pb-24 sm:pt-20 sm:pb-32">
    <div class="container-edge grid lg:grid-cols-12 gap-12 items-start">
      <div class="lg:col-span-7">
        <div data-reveal class="text-xs uppercase tracking-[0.22em] text-[--color-vermillion-600] mb-4">संपर्क</div>
        <h1 data-reveal class="text-5xl sm:text-7xl text-[--color-ink-900] text-balance leading-[1.05]">
          {tr("contact.title")}
        </h1>
        <p data-reveal class="mt-7 text-lg sm:text-xl text-[--color-ink-600] max-w-xl text-pretty leading-relaxed">
          {tr("contact.subtitle")}
        </p>

        <div data-reveal class="mt-10 flex flex-col sm:flex-row gap-4">
          <a href={whatsappLink(lang)} target="_blank" rel="noopener" class="btn text-base bg-[#25D366] text-white hover:bg-[#1ebe5a] hover:scale-[1.02] active:scale-[0.98]">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1s-.8.9-.9 1.1c-.2.2-.3.2-.6.1-1.7-.9-2.9-1.5-4-3.5-.3-.5.3-.5.9-1.6.1-.2.1-.4 0-.5s-.7-1.6-.9-2.2c-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.2.2 2.1 3.2 5.1 4.5 1.9.8 2.6.9 3.5.7.6-.1 1.7-.7 2-1.4.2-.7.2-1.3.2-1.4-.1-.1-.3-.2-.6-.3zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.6 1.4 5.1L2 22l5-1.4c1.5.8 3.2 1.3 5 1.3 5.5 0 10-4.5 10-10S17.5 2 12 2z"/>
            </svg>
            {tr("contact.whatsapp")}
          </a>
          <a href={`tel:+${SITE.contact.whatsapp}`} class="btn-secondary text-base">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            {SITE.contact.whatsappDisplay}
          </a>
        </div>

        <p data-reveal class="mt-6 text-sm text-[--color-ink-500]">{tr("contact.note")}</p>
      </div>

      <aside class="lg:col-span-5">
        <div data-reveal class="p-7 sm:p-9 rounded-3xl bg-gradient-to-br from-ink-900 to-ink-700 text-white">
          <div class="text-xs uppercase tracking-[0.22em] text-[--color-saffron-400] mb-5">{tr("contact.serves.title")}</div>
          <ul data-reveal-stagger class="space-y-3">
            {serves.map((s) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 text-[--color-saffron-400]">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
                <span class="text-[15px] text-white/90 leading-snug">{s}</span>
              </li>
            ))}
          </ul>

          <div class="mt-8 pt-6 border-t border-white/10 text-xs text-white/60 leading-relaxed">
            स्टूडियो मुंबई में स्थित। साइट विज़िट एवं ऑन-साइट कार्य के लिए शहर भर में उपलब्ध।
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
