---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFloat from "../components/WhatsAppFloat.astro";
import { SITE } from "../config";
import { type Lang, getLangFromUrl } from "../i18n/ui";

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
  hideHeader?: boolean;
}

const { title, description, lang: langProp, hideHeader = false } = Astro.props;
const lang: Lang = langProp ?? getLangFromUrl(Astro.url);
const pageTitle = title ? `${title} — ${SITE.name}` : `${SITE.name} — ${SITE.tagline[lang]}`;
const pageDesc = description ?? SITE.subtitle[lang];
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang={lang} dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta name="author" content={SITE.artist} />
    <meta name="theme-color" content="#0d0c08" />

    <link rel="icon" type="image/png" href={`${base}/favicon.png`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}/favicon-32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${base}/favicon-16.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}/apple-touch-icon.png`} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:image" content={`${SITE.url}/og-image.jpg`} />
    <meta property="og:locale" content={lang === "hi" ? "hi_IN" : "en_IN"} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="canonical" href={`${SITE.url}${Astro.url.pathname}`} />
    <link rel="alternate" hreflang="en" href={`${SITE.url}${Astro.url.pathname.replace(/^\/hi/, "") || "/"}`} />
    <link rel="alternate" hreflang="hi" href={`${SITE.url}/hi${Astro.url.pathname.replace(/^\/hi/, "") || "/"}`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Inter:wght@300;400;500;600;700&family=Noto+Sans+Devanagari:wght@400;500;600;700&display=swap"
    />

    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col bg-[--color-ink-50] text-[--color-ink-800]">
    {!hideHeader && <Header lang={lang} />}
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
    <WhatsAppFloat lang={lang} />

    <script>
      const reveal = () => {
        const els = document.querySelectorAll("[data-reveal], [data-reveal-stagger]");
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
        );
        els.forEach((el) => io.observe(el));
      };
      reveal();
      document.addEventListener("astro:page-load", reveal);
    </script>
  </body>
</html>
