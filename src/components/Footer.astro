---
import { SITE, whatsappLink } from "../config";
import { t, localizedPath, type Lang } from "../i18n/ui";

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-[--color-ink-200] bg-[--color-ink-100]/40">
  <div class="container-edge py-14 grid gap-10 md:grid-cols-3">
    <div>
      <div class="font-[family-name:var(--font-display)] text-2xl text-[--color-ink-900]">
        Pradeep <span class="italic text-[--color-vermillion-600]">Arts</span> Studio
      </div>
      <p class="mt-3 text-sm text-[--color-ink-600] leading-relaxed max-w-sm">
        {tr("footer.built")}
      </p>
    </div>

    <div>
      <div class="text-xs uppercase tracking-[0.2em] text-[--color-ink-500] mb-4">
        {lang === "hi" ? "मेन्यू" : "Menu"}
      </div>
      <ul class="space-y-2 text-sm">
        <li><a href={localizedPath("/", lang)} class="hover:text-[--color-vermillion-600] transition-colors">{tr("nav.home")}</a></li>
        <li><a href={localizedPath("/work", lang)} class="hover:text-[--color-vermillion-600] transition-colors">{tr("nav.work")}</a></li>
        <li><a href={localizedPath("/about", lang)} class="hover:text-[--color-vermillion-600] transition-colors">{tr("nav.about")}</a></li>
        <li><a href={localizedPath("/contact", lang)} class="hover:text-[--color-vermillion-600] transition-colors">{tr("nav.contact")}</a></li>
      </ul>
    </div>

    <div>
      <div class="text-xs uppercase tracking-[0.2em] text-[--color-ink-500] mb-4">
        {lang === "hi" ? "संपर्क" : "Get in touch"}
      </div>
      <a
        href={whatsappLink(lang)}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 text-sm font-medium text-[--color-ink-900] hover:text-[--color-vermillion-600] transition-colors group"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-[#25D366] group-hover:scale-110 transition-transform">
          <path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1s-.8.9-.9 1.1c-.2.2-.3.2-.6.1-1.7-.9-2.9-1.5-4-3.5-.3-.5.3-.5.9-1.6.1-.2.1-.4 0-.5s-.7-1.6-.9-2.2c-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.2.2 2.1 3.2 5.1 4.5 1.9.8 2.6.9 3.5.7.6-.1 1.7-.7 2-1.4.2-.7.2-1.3.2-1.4-.1-.1-.3-.2-.6-.3zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.6 1.4 5.1L2 22l5-1.4c1.5.8 3.2 1.3 5 1.3 5.5 0 10-4.5 10-10S17.5 2 12 2zm0 18.2c-1.6 0-3.1-.4-4.4-1.2l-.3-.2-3 .8.8-2.9-.2-.3c-.9-1.4-1.4-3-1.4-4.6 0-4.5 3.7-8.2 8.2-8.2 4.5 0 8.2 3.7 8.2 8.2.1 4.5-3.6 8.4-8.1 8.4z"/>
        </svg>
        {SITE.contact.whatsappDisplay}
      </a>
    </div>
  </div>

  <div class="border-t border-[--color-ink-200]/60">
    <div class="container-edge py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-[--color-ink-500]">
      <div>© {year} {SITE.name}. {tr("footer.rights")}</div>
      <div class="flex items-center gap-1.5">
        <span class="inline-block w-1 h-1 rounded-full bg-[--color-vermillion-500]"></span>
        <span>Mumbai, India</span>
      </div>
    </div>
  </div>
</footer>
