---
import { Image } from "astro:assets";
import { SITE, whatsappLink } from "../config";
import { t, localizedPath, type Lang } from "../i18n/ui";
import { featured } from "../data/paintings";

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);

const heroPick = featured[0]?.src;
const sidePicks = featured.slice(1, 4).map((p) => p.src);
---

<section class="relative pt-10 sm:pt-16 pb-20 sm:pb-28 overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(80%_60%_at_30%_0%,rgba(244,168,58,0.12),transparent_60%),radial-gradient(60%_50%_at_90%_20%,rgba(210,63,44,0.08),transparent_60%)]"></div>

  <div class="container-edge grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">
    <div class="lg:col-span-6">
      <div data-reveal class="inline-flex items-center gap-2 px-3 py-1.5 mb-7 rounded-full bg-[--color-ink-100] border border-[--color-ink-200]">
        <span class="relative flex w-2 h-2">
          <span class="absolute inline-flex w-full h-full rounded-full bg-[--color-vermillion-500] opacity-70 animate-ping"></span>
          <span class="relative inline-flex w-2 h-2 rounded-full bg-[--color-vermillion-600]"></span>
        </span>
        <span class="text-[11px] uppercase tracking-[0.18em] text-[--color-ink-700]">
          {lang === "hi" ? "नए कार्य ले रहे हैं" : "Taking on new work"}
        </span>
      </div>

      <h1 data-reveal class="text-[clamp(3rem,7vw,6rem)] leading-[0.95] text-[--color-ink-900] tracking-tight">
        {lang === "hi" ? (
          <>हर दीवार,<br/><span class="italic font-[family-name:var(--font-display)] text-[--color-vermillion-600]">एक कहानी।</span></>
        ) : (
          <>Every wall,<br/><span class="italic text-[--color-vermillion-600]">a story.</span></>
        )}
      </h1>

      <p data-reveal class="mt-7 text-lg sm:text-xl text-[--color-ink-600] max-w-xl text-pretty leading-relaxed">
        {SITE.subtitle[lang]}
      </p>

      <div data-reveal class="mt-10 flex flex-wrap items-center gap-3">
        <a href={localizedPath("/work", lang)} class="btn-primary text-base">
          {tr("hero.cta.work")}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
        <a href={whatsappLink(lang)} target="_blank" rel="noopener" class="btn-secondary text-base">
          {tr("hero.cta.contact")}
        </a>
      </div>

      <dl data-reveal-stagger class="mt-14 grid grid-cols-3 gap-4 sm:gap-8 max-w-md">
        <div>
          <dt class="text-3xl sm:text-4xl font-[family-name:var(--font-display)] text-[--color-ink-900] tabular-nums">25<span class="text-[--color-vermillion-500]">+</span></dt>
          <dd class="mt-1 text-[11px] uppercase tracking-[0.16em] text-[--color-ink-500]">{tr("stats.years")}</dd>
        </div>
        <div>
          <dt class="text-3xl sm:text-4xl font-[family-name:var(--font-display)] text-[--color-ink-900] tabular-nums">500<span class="text-[--color-vermillion-500]">+</span></dt>
          <dd class="mt-1 text-[11px] uppercase tracking-[0.16em] text-[--color-ink-500]">{tr("stats.works")}</dd>
        </div>
        <div>
          <dt class="text-3xl sm:text-4xl font-[family-name:var(--font-display)] text-[--color-ink-900] tabular-nums">12<span class="text-[--color-vermillion-500]">+</span></dt>
          <dd class="mt-1 text-[11px] uppercase tracking-[0.16em] text-[--color-ink-500]">{tr("stats.cities")}</dd>
        </div>
      </dl>
    </div>

    <div class="lg:col-span-6 relative">
      <div class="relative grid grid-cols-6 grid-rows-6 gap-3 sm:gap-4 aspect-[5/6] max-w-[640px] mx-auto">
        <div data-reveal class="col-span-4 row-span-4 relative rounded-3xl overflow-hidden shadow-2xl shadow-[--color-ink-700]/15 ring-1 ring-[--color-ink-200]">
          {heroPick && (
            <Image
              src={heroPick}
              alt="Featured mural"
              widths={[600, 900, 1200]}
              sizes="(min-width: 1024px) 40vw, 90vw"
              loading="eager"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1500ms] hover:scale-110"
            />
          )}
          <div class="absolute inset-x-0 bottom-0 p-4 bg-gradient-to-t from-black/60 to-transparent text-white text-xs uppercase tracking-[0.2em]">
            {lang === "hi" ? "हाल का कार्य" : "Recent work"}
          </div>
        </div>

        {sidePicks[0] && (
          <div data-reveal class="col-span-2 row-span-2 col-start-5 row-start-1 relative rounded-2xl overflow-hidden shadow-lg ring-1 ring-[--color-ink-200]">
            <Image src={sidePicks[0]} alt="" widths={[300, 500]} sizes="20vw" loading="eager" class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 hover:scale-110" />
          </div>
        )}
        {sidePicks[1] && (
          <div data-reveal class="col-span-2 row-span-2 col-start-5 row-start-3 relative rounded-2xl overflow-hidden shadow-lg ring-1 ring-[--color-ink-200]">
            <Image src={sidePicks[1]} alt="" widths={[300, 500]} sizes="20vw" loading="eager" class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 hover:scale-110" />
          </div>
        )}
        {sidePicks[2] && (
          <div data-reveal class="col-span-3 row-span-2 col-start-1 row-start-5 relative rounded-2xl overflow-hidden shadow-lg ring-1 ring-[--color-ink-200]">
            <Image src={sidePicks[2]} alt="" widths={[400, 700]} sizes="30vw" loading="eager" class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 hover:scale-110" />
          </div>
        )}

        <div class="col-span-3 row-span-2 col-start-4 row-start-5 rounded-2xl bg-[--color-ink-900] text-white p-5 sm:p-6 flex flex-col justify-between">
          <div class="text-xs uppercase tracking-[0.2em] text-white/60">
            {lang === "hi" ? "विशेषज्ञता" : "Specialties"}
          </div>
          <ul class="text-[13px] sm:text-sm space-y-1.5 leading-snug">
            <li class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-[--color-saffron-400]"></span>{lang === "hi" ? "धार्मिक चित्रकला" : "Devotional murals"}</li>
            <li class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-[--color-vermillion-500]"></span>{lang === "hi" ? "साइनबोर्ड" : "Storefront signs"}</li>
            <li class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-[--color-jade-500]"></span>{lang === "hi" ? "मूर्ति चित्रण" : "Idol painting"}</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
